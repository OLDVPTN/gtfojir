# Database Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_SSL=true
DB_TABLE_NAME=gatofo_state
DB_STATE_KEY=main
DB_SAVE_DEBOUNCE_MS=350

# WhatsApp
# PHONE_NUMBER tidak wajib lagi karena pairing bisa dari web
PHONE_NUMBER=
BOT_NUMBER=628xxxxxxxxxx
OWNER_NUMBERS=628xxxxxxxxxx
CUSTOM_PAIRING=GATOFO25
USE_CUSTOM_PAIRING=false
SESSION_DIR=session
STORE_PATH=./store.json

# Gatofo
BOT_NAME=Gatofo Core Cell
BOT_FOOTER=Gatofo Core Cell — Poko Group
DEFAULT_CITY=Malang
DEFAULT_AVG_TICKET=25000
ALLOW_GROUPS=false

# Category Detection
USE_OLLAMA_FOR_CATEGORY=true
CATEGORY_CONFIDENCE_THRESHOLD=0.72

# Ollama
OLLAMA_BASE_URL=https://desktop-bh6k0ih.taildd515d.ts.net/api/tags
OLLAMA_MODEL=
OLLAMA_TIMEOUT_MS=25000

# Render
PORT=3000
RECONNECT_MS=5000
NODE_VERSION=20

# Pairing fix
PAIRING_READY_DELAY_MS=1800
